{
  "name": "franja-pixelada-e2e",
  "version": "1.0.0",
  "description": "Tests E2E + auditoría CSP runtime — Franja Pixelada",
  "private": true,
  "scripts": {
    "test":         "playwright test",
    "test:csp":     "playwright test specs/01-csp-audit.spec.js",
    "test:flows":   "playwright test --ignore=specs/01-csp-audit.spec.js",
    "test:ui":      "playwright test --ui",
    "test:debug":   "playwright test --debug",
    "test:headed":  "playwright test --headed",
    "report":       "playwright show-report reports/playwright",
    "install:browsers": "playwright install chromium",
    "audit:static": "node ../../scripts/audit/csp_audit.py",
    "audit:csp":    "node ../../scripts/audit/run_audit.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0"
  }
}
