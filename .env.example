# ═══════════════════════════════════════════════════
#  TactiStore / Franja Pixelada — Plantilla de entorno
#  Copia este archivo como .env y completa los valores
#  NUNCA subas .env al repositorio
# ═══════════════════════════════════════════════════

# ── DJANGO ──────────────────────────────────────────
# Genera con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esta-clave-por-una-generada
DEBUG=False
ALLOWED_HOSTS=tudominio.com,www.tudominio.com

# ── BASE DE DATOS ────────────────────────────────────
DB_NAME=franja_pixelada_store
DB_USER=postgres
DB_PASSWORD=cambia-esta-contrasena
DB_HOST=db
DB_PORT=5432
# Segundos de persistencia de conexión PostgreSQL (0 = nueva conexión por request).
# En prod con varios workers de Gunicorn suele usarse 60–300; en DEBUG por defecto 0 si no se define.
DB_CONN_MAX_AGE=120

# ── GUNICORN (imagen Docker / entrypoint) ───────────
# Regla orientativa: ~2 * CPUs + 1 worker. GUNICORN_THREADS>0 usa --worker-class gthread; 0 = sync.
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120

# ── ARRANQUE DOCKER (desarrollo) ─────────────────────
# true: no ejecuta collectstatic al iniciar el contenedor (útil con DEBUG=True para reinicios rápidos).
SKIP_COLLECTSTATIC_ON_START=false

# ── REDIS ────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=cambia-esta-contrasena-redis
REDIS_PORT=6379

# ── CORS ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://tudominio.com

# ── PROXY / IP ───────────────────────────────────────
TRUSTED_PROXY_COUNT=1

# ── PANEL ADMINISTRADOR ──────────────────────────────
# Cambia "admin/" por algo no predecible en producción
ADMIN_URL=admin/
ADMIN_SECURITY_EMAIL=tu-email-de-alertas@dominio.com
DISABLE_ADMIN_OTP=False

# ── PROVEEDORES (solo desarrollo local) ────────────────────────────────────────
# True = aceptar webhooks sin webhook_secret ni firma HMAC (NUNCA en producción).
WEBHOOK_ALLOW_UNSIGNED=False

# ── PAGOS ─────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=live

# ── EMAIL ─────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu-correo@gmail.com
EMAIL_HOST_PASSWORD=contrasena-de-aplicacion-gmail
DEFAULT_FROM_EMAIL=Franja Pixelada <noreply@tudominio.com>

# ── PRECIOS ──────────────────────────────────────────
TAX_RATE=0.19
FREE_SHIPPING_THRESHOLD=200000
BASE_SHIPPING_COST=15000

# ── Nequi (pago manual — textos mostrados al cliente en checkout; demo) ──────
NEKI_DISPLAY_PHONE=+57 300 000 0000
NEKI_DISPLAY_ACCOUNT_NAME=Franja Pixelada S.A.S. (demo)
